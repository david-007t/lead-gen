# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase — set these in Vercel dashboard under Project Settings > Environment Variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SMTP — server-side only. Never send these from the client.
# Used by api/send-email.js. All values are read from env vars at runtime.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=Your Name
